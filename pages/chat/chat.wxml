<view class="chat-page">
  <view class="chat-header">
    <image src="{{roleInfo.avatar}}" class="avatar"/>
    <view class="name">{{roleInfo.name}}</view>
  </view>

  <!-- <scroll-view scroll-y class="chat-history">
    <block wx:for="{{messages}}" wx:key="id">
      <chat-bubble msg="{{item}}" />
    </block>
  </scroll-view> -->

  <!-- <block wx:for="{{messages}}" wx:key="id">
    <view class="chat-bubble {{item.from==='user'?'chat-right':'chat-left'}}">
      <user-avatar avatar="{{item.from==='user'?userAvatar:roleAvatar}}" />
      <view class="bubble-content">{{item.content}}</view>
    </view>
  </block> -->
  
  <scroll-view scroll-y style="height:auto;">
    <block wx:for="{{messages}}" wx:key="id">
      <view>{{item.content}}</view>
    </block>
  </scroll-view>

  <view class="chat-input">
    <input type="text" value="{{inputMsg}}" bindinput="onInput"/>
    <button bindtap="sendMsg">发送</button>
  </view>
</view>